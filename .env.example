# Copy to .env.local for local dev; set the same keys in Vercel project env for prod.
# Leave SUPABASE_* empty to run in mock mode (in-memory, counts reset on restart).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin backend password (what users type on /#/admin login)
ADMIN_PASSWORD=13579

# HMAC key for signing admin session cookies. Generate any random string.
ADMIN_SECRET=change-me-to-a-random-string
